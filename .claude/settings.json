{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git commit *)",
            "command": "(colima status 2>/dev/null || colima start) && DOCKER_HOST=\"unix:///Users/clov/.colima/default/docker.sock\" /usr/local/bin/act --container-daemon-socket - -P ubuntu-latest=catthehacker/ubuntu:act-22.04 push",
            "timeout": 600,
            "statusMessage": "Running act (GitHub Actions)..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // .tool_response.filePath' | { read -r f; echo \"$f\" | grep -qE '^(public/js|tests)/' && bun test; } 2>/dev/null || true",
            "statusMessage": "Running tests..."
          }
        ]
      }
    ]
  }
}
